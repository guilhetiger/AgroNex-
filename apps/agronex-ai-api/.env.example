# Backend Next.js (apps/agronex-ai-api/.env.local)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-key

# Vertex AI (Gemini en Google Cloud)
GOOGLE_CLOUD_PROJECT=your-gcp-project-id
GOOGLE_CLOUD_LOCATION=us-central1
# Alias opcional (misma region que GOOGLE_CLOUD_LOCATION):
# GOOGLE_LOCATION=us-central1

# Autenticacion — elige UNA opcion:
# A) ADC en local (recomendado): gcloud auth application-default login
# B) Service account JSON: descomenta y apunta al archivo .json
# GOOGLE_APPLICATION_CREDENTIALS=C:/path/to/service-account.json

# Opcional — nunca para leer datos de negocio
SUPABASE_SERVICE_ROLE_KEY=

# Expo (.env.local raíz)
EXPO_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
EXPO_PUBLIC_AI_API_URL=http://localhost:3000
