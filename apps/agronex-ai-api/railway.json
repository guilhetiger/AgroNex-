{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "NIXPACKS",
    "buildCommand": "npm run build"
  },
  "deploy": {
    "startCommand": "npx next start -p $PORT -H 0.0.0.0",
    "restartPolicyType": "ON_FAILURE",
    "healthCheckPath": "/api/health",
    "healthCheckTimeout": 30
  }
}
